{
  "name": "@forge/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": ["**/*.css"],
  "files": ["dist", "src/styles/forge-ui.css", "README.md"],
  "main": "./dist/index.js",
